{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "off",
				"noUselessFragments": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noArrayIndexKey": "off"
			},
			"a11y": {
				"useKeyWithClickEvents": "warn",
				"useFocusableInteractive": "off"
			}
		}
	},
	"formatter": {
		"lineWidth": 120,
		"indentWidth": 4,
		"enabled": true,
		"includes": ["!node_modules/*", "!*.config.*", "!*.json", "!tsconfig.json", "!.turbo"]
	}
}
