{
  "name": "@repo/database",
  "version": "1.0.0",
  "main": "index.js",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "format-and-lint": "biome check ./src",
    "format-and-lint:fix": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "with-env": "dotenv -e ../../.env --",
    "db:migrate": "pnpm with-env tsx scripts/migration.ts",
    "db:studio": "pnpm with-env drizzle-kit studio",
    "db:generate": "pnpm with-env drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@repo/typescript-config": "workspace:*",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.21.0"
  }
}
